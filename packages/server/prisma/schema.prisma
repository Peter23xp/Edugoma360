generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model School {
  id                  String    @id @default(uuid())
  name                String
  logoUrl             String?
  type                String
  convention          String?
  agrement            String?
  province            String    @default("Nord-Kivu")
  ville               String    @default("Goma")
  commune             String?
  adresse             String?
  telephone           String?
  email               String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  logoThumbnailUrl    String?
  logoIconUrl         String?
  avenue              String?
  numero              String?
  reference           String?
  telephonePrincipal  String?
  telephoneSecondaire String?
  siteWeb             String?
  numeroAgrement      String?
  dateAgrement        DateTime?
  devise              String?
  langueEnseignement  String? // FRANCAIS, ANGLAIS, BILINGUE
  systemeEvaluation   String? // NOTE_20, NOTE_10, MIXTE
  nombrePeriodes      String? // TRIMESTRES, SEMESTRES
  nomOfficiel         String?
  nomCourt            String?
  code                String?   @unique

  // ── SaaS / Multi-Tenant ──────────────────────────────────────────────────
  subdomain    String?          @unique   // ex: "mungano" → mungano.edugoma360.cd
  planId       String?
  plan         SubscriptionPlan? @relation(fields: [planId], references: [id])
  trialEndsAt  DateTime?         // Fin de la période d'essai gratuit

  subscriptions       Subscription[]
  academicYears       AcademicYear[]
  classes             Class[]
  feeTypes            FeeType[]
  payments            Payment[]
  paymentPlans        PaymentPlan[]
  sections            Section[]
  settings            Setting[]
  smsLogs             SmsLog[]
  students            Student[]
  subjects            Subject[]
  teacherAttendances  TeacherAttendance[]
  teacherLeaves       TeacherLeave[]
  teachers            Teacher[]
  users               User[]
  cashSessions        CashSession[]
  budgets             Budget[]
  justifications      Justification[]
  smsCampaigns        SMSCampaign[]
  emailCampaigns      EmailCampaign[]
  convocations        Convocation[]
  announcements       Announcement[]
  savedReports        SavedReport[]
  exportHistory       ExportHistory[]
  exportSchedules     ExportSchedule[]
  materialItems       MaterialItem[]
  books               Book[]
  rooms               Room[]
  maintenanceRequests MaintenanceRequest[]

  @@map("schools")
}

model User {
  id                      String               @id @default(uuid())
  schoolId                String?              // null = Super Admin de la plateforme (indépendant de toute école)
  nom                     String
  postNom                 String
  prenom                  String?
  email                   String?
  phone                   String?
  passwordHash            String
  role                    String
  isSuperAdmin            Boolean              @default(false) // Super Admin de la plateforme SaaS
  permissions             String?              @default("{}")
  isActive                Boolean              @default(true)
  mustChangePassword      Boolean              @default(true)
  lastLoginAt             DateTime?
  lastLoginIp             String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  attendanceTaken         Attendance[]
  gradesCreated           Grade[]
  paymentsCreated         Payment[]
  teacherAttendanceTaken  TeacherAttendance[]
  leaveProcessing         TeacherLeave[]       @relation("LeaveProcessor")
  cashSessions            CashSession[]        @relation("CashSessions")
  justificationsSubmitted Justification[]      @relation("JustificationSubmitter")
  justificationsReviewed  Justification[]      @relation("JustificationReviewer")
  teacher                 Teacher?
  school                  School?              @relation(fields: [schoolId], references: [id])
  parentStudents          Student[]            @relation("ParentStudents")
  smsCampaignsCreated     SMSCampaign[]
  emailCampaignsCreated   EmailCampaign[]      @relation("EmailCampaignCreator")
  convocationsCreated     Convocation[]        @relation("ConvocationCreator")
  announcementsCreated    Announcement[]       @relation("AnnouncementCreator")
  announcementViews       AnnouncementView[]   @relation("AnnouncementViews")
  savedReports            SavedReport[]        @relation("SavedReportCreator")
  exportHistories         ExportHistory[]      @relation("ExportHistoryCreator")
  exportSchedules         ExportSchedule[]     @relation("ExportScheduleCreator")
  stockMovements          StockMovement[]      @relation("StockMovementCreator")
  bookLoansCreated        BookLoan[]           @relation("BookLoanCreator")
  maintenanceReports      MaintenanceRequest[] @relation("MaintenanceReporter")

  @@unique([schoolId, phone])
  @@unique([schoolId, email])
  @@map("users")
}

model OtpToken {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_tokens")
}

model AcademicYear {
  id          String       @id @default(uuid())
  schoolId    String
  label       String
  name        String? // Pour compatibilité API SCR-033
  startDate   DateTime
  endDate     DateTime
  type        String? // TRIMESTRES | SEMESTRES
  isActive    Boolean      @default(false)
  isClosed    Boolean      @default(false)
  closedAt    DateTime?
  closedById  String?
  createdAt   DateTime     @default(now())
  school      School       @relation(fields: [schoolId], references: [id])
  enrollments Enrollment[]
  feeTypes    FeeType[]
  payments    Payment[]
  terms       Term[]
  budgets     Budget[]

  @@unique([schoolId, label])
  @@map("academic_years")
}

model Term {
  id             String         @id @default(uuid())
  academicYearId String
  number         Int
  label          String
  startDate      DateTime
  endDate        DateTime
  examStartDate  DateTime?
  examEndDate    DateTime?
  isActive       Boolean        @default(false)
  attendances    Attendance[]
  deliberations  Deliberation[]
  grades         Grade[]
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@unique([academicYearId, number])
  @@map("terms")
}

model Section {
  id       String           @id @default(uuid())
  schoolId String
  name     String
  code     String
  year     Int
  classes  Class[]
  school   School           @relation(fields: [schoolId], references: [id])
  subjects SubjectSection[]

  @@unique([schoolId, code, year])
  @@map("sections")
}

model Class {
  id                 String                @id @default(uuid())
  schoolId           String
  sectionId          String
  name               String
  titulaireId        String?
  maxStudents        Int                   @default(45)
  isActive           Boolean               @default(true)
  titulaire          Teacher?              @relation("ClassTitulaire", fields: [titulaireId], references: [id])
  attendances        Attendance[]
  section            Section               @relation(fields: [sectionId], references: [id])
  school             School                @relation(fields: [schoolId], references: [id])
  deliberations      Deliberation[]
  enrollments        Enrollment[]
  teacherAssignments TeacherClassSubject[]
  assignedRoom       Room?                 @relation("RoomAssignedClass")

  @@unique([schoolId, name])
  @@map("classes")
}

model Subject {
  id            String                @id @default(uuid())
  schoolId      String
  name          String
  abbreviation  String
  maxScore      Int                   @default(20)
  isEliminatory Boolean               @default(false)
  elimThreshold Float?
  displayOrder  Int                   @default(0)
  grades        Grade[]
  sections      SubjectSection[]
  school        School                @relation(fields: [schoolId], references: [id])
  assignments   TeacherClassSubject[]
  teachers      Teacher[]             @relation("TeacherSubjects")

  @@unique([schoolId, abbreviation])
  @@map("subjects")
}

model SubjectSection {
  subjectId   String
  sectionId   String
  coefficient Int     @default(1)
  section     Section @relation(fields: [sectionId], references: [id])
  subject     Subject @relation(fields: [subjectId], references: [id])

  @@id([subjectId, sectionId])
  @@map("subject_sections")
}

model Student {
  id                String             @id @default(uuid())
  schoolId          String
  matricule         String
  nom               String
  postNom           String
  prenom            String?
  sexe              String
  dateNaissance     DateTime
  lieuNaissance     String
  nationalite       String             @default("Congolaise")
  photoUrl          String?
  nomPere           String?
  telPere           String?
  nomMere           String?
  telMere           String?
  nomTuteur         String?
  telTuteur         String?
  parentUserId      String?
  parentUser        User?              @relation("ParentStudents", fields: [parentUserId], references: [id])
  statut            String             @default("NOUVEAU")
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendances       Attendance[]
  disciplineRecords DisciplineRecord[]
  enrollments       Enrollment[]
  grades            Grade[]
  payments          Payment[]
  paymentPlans      PaymentPlan[]
  justifications    Justification[]
  convocations      Convocation[]
  delibResults      DelibResult[]
  bookLoans         BookLoan[]
  school            School             @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, matricule])
  @@map("students")
}

model Enrollment {
  id               String       @id @default(uuid())
  studentId        String
  classId          String
  academicYearId   String
  ecoleOrigine     String?
  resultatTenasosp Float?
  enrolledAt       DateTime     @default(now())
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id])
  class            Class        @relation(fields: [classId], references: [id])
  student          Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, academicYearId])
  @@map("enrollments")
}

model Teacher {
  id               String                @id @default(uuid())
  schoolId         String
  matricule        String                @unique
  matriculeMepst   String?
  nom              String
  postNom          String
  prenom           String?
  sexe             String
  dateNaissance    DateTime?
  lieuNaissance    String?
  nationalite      String                @default("Congolaise")
  telephone        String?
  email            String?
  adresse          String?
  photoUrl         String?
  niveauEtudes     String?
  domaineFormation String?
  universite       String?
  anneeObtention   Int?
  specialisations  String?
  compteBancaire   String?
  statut           String                @default("ACTIF")
  dateEmbauche     DateTime?
  typeContrat      String?
  fonction         String?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  userId           String?               @unique
  congeGlobal      Int                   @default(20)
  congePris        Int                   @default(0)
  attendances      TeacherAttendance[]
  certificats      TeacherCertificate[]
  assignments      TeacherClassSubject[]
  titulaireClasses Class[]               @relation("ClassTitulaire")
  roomsResponsable Room[]                @relation("RoomResponsable")
  leaves           TeacherLeave[]
  user             User?                 @relation(fields: [userId], references: [id])
  school           School                @relation(fields: [schoolId], references: [id])
  subjects         Subject[]             @relation("TeacherSubjects")

  @@unique([schoolId, telephone])
  @@map("teachers")
}

model TeacherLeave {
  id            String   @id @default(uuid())
  teacherId     String
  schoolId      String
  type          String
  startDate     DateTime
  endDate       DateTime
  daysCount     Int
  status        String   @default("PENDING")
  reason        String
  observations  String?
  certificatUrl String?
  processedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  processedBy   User?    @relation("LeaveProcessor", fields: [processedById], references: [id])
  school        School   @relation(fields: [schoolId], references: [id])
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_leaves")
}

model TeacherCertificate {
  id         String  @id @default(uuid())
  teacherId  String
  nom        String
  organisme  String
  annee      Int
  fichierUrl String?
  teacher    Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_certificates")
}

model TeacherClassSubject {
  id               String            @id @default(uuid())
  teacherId        String
  classId          String
  subjectId        String
  academicYearId   String
  volumeHoraire    Int?              @default(0)
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class            Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher          Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  timetablePeriods TimetablePeriod[]

  @@unique([teacherId, classId, subjectId, academicYearId])
  @@map("teacher_class_subjects")
}

model TimetablePeriod {
  id                    String              @id @default(uuid())
  teacherClassSubjectId String
  dayOfWeek             String
  periodSlot            Int
  startTime             String
  endTime               String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  teacherClassSubject   TeacherClassSubject @relation(fields: [teacherClassSubjectId], references: [id], onDelete: Cascade)

  @@unique([teacherClassSubjectId, dayOfWeek, periodSlot])
  @@index([dayOfWeek, periodSlot])
  @@map("timetable_periods")
}

model Grade {
  id          String   @id @default(uuid())
  studentId   String
  subjectId   String
  termId      String
  evalType    String
  score       Float
  maxScore    Int      @default(20)
  observation String?
  isLocked    Boolean  @default(false)
  syncStatus  String   @default("SYNCED")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id])
  term        Term     @relation(fields: [termId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id], onDelete: NoAction)

  @@unique([studentId, subjectId, termId, evalType])
  @@map("grades")
}

model Deliberation {
  id          String        @id @default(uuid())
  classId     String
  termId      String
  status      String        @default("DRAFT")
  validatedAt DateTime?
  pvUrl       String?
  createdAt   DateTime      @default(now())
  results     DelibResult[]
  term        Term          @relation(fields: [termId], references: [id])
  class       Class         @relation(fields: [classId], references: [id])

  @@unique([classId, termId])
  @@map("deliberations")
}

model DelibResult {
  id             String       @id @default(uuid())
  deliberationId String
  studentId      String
  generalAverage Float
  totalPoints    Float
  rank           Int
  decision       String
  justification  String?
  deliberation   Deliberation @relation(fields: [deliberationId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id])

  @@unique([deliberationId, studentId])
  @@map("delib_results")
}

model Attendance {
  id             String          @id @default(uuid())
  studentId      String
  classId        String
  termId         String
  date           DateTime
  period         String
  status         String
  justification  String?
  syncStatus     String          @default("SYNCED")
  recordedById   String
  createdAt      DateTime        @default(now())
  recordedBy     User            @relation(fields: [recordedById], references: [id])
  term           Term            @relation(fields: [termId], references: [id])
  class          Class           @relation(fields: [classId], references: [id])
  student        Student         @relation(fields: [studentId], references: [id])
  justifications Justification[]

  @@unique([studentId, date, period])
  @@map("attendances")
}

model TeacherAttendance {
  id            String   @id @default(uuid())
  teacherId     String
  schoolId      String
  date          DateTime
  status        String
  justification String?
  recordedById  String
  createdAt     DateTime @default(now())
  recordedBy    User     @relation(fields: [recordedById], references: [id])
  school        School   @relation(fields: [schoolId], references: [id])
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, date])
  @@map("teacher_attendances")
}

model DisciplineRecord {
  id          String   @id @default(uuid())
  studentId   String
  date        DateTime
  description String
  witnesses   String?
  sanction    String
  status      String   @default("OPEN")
  resolution  String?
  createdAt   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id])

  @@map("discipline_records")
}

model FeeType {
  id             String        @id @default(uuid())
  schoolId       String
  academicYearId String?
  type           String        @default("AUTRE")
  name           String
  amount         Int
  scope          String        @default("SCHOOL")
  sectionIds     String        @default("[]")
  classIds       String        @default("[]")
  frequency      String        @default("ANNUAL")
  months         String        @default("[]")
  termNumber     Int?
  isRequired     Boolean       @default(true)
  observations   String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  deletedAt      DateTime?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id])
  feePayments    FeePayment[]

  @@index([schoolId, academicYearId, isActive])
  @@map("fee_types")
}

model Payment {
  id             String @id @default(uuid())
  schoolId       String
  academicYearId String
  receiptNumber  String @unique
  studentId      String

  // Montants
  totalDue         Int
  amountPaid       Int
  remainingBalance Int    @default(0)
  currency         String @default("FC")
  exchangeRate     Float?

  // Méthode de paiement
  paymentMethod  String
  transactionRef String?
  paymentDate    DateTime @default(now())

  // Métadonnées
  cashierId    String
  observations String?
  receiptUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relations
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id])
  student      Student      @relation(fields: [studentId], references: [id])
  cashier      User         @relation(fields: [cashierId], references: [id])
  feePayments  FeePayment[]

  @@index([schoolId, studentId])
  @@index([receiptNumber])
  @@index([paymentDate])
  @@map("payments")
}

model PaymentPlan {
  id           String   @id @default(uuid())
  studentId    String
  schoolId     String
  totalAmount  Int
  installments Int
  startDate    DateTime
  status       String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student  Student       @relation(fields: [studentId], references: [id])
  school   School        @relation(fields: [schoolId], references: [id])
  schedule Installment[]

  @@map("payment_plans")
}

model Installment {
  id         String    @id @default(uuid())
  planId     String
  dueDate    DateTime
  amount     Int
  amountPaid Int       @default(0)
  status     String    @default("PENDING") // PENDING, PAID, OVERDUE
  paidAt     DateTime?

  plan PaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("installments")
}

model FeePayment {
  id         String   @id @default(uuid())
  paymentId  String
  feeId      String
  amountDue  Int
  amountPaid Int
  createdAt  DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  fee     FeeType @relation(fields: [feeId], references: [id])

  @@unique([paymentId, feeId])
  @@map("fee_payments")
}

model SmsLog {
  id        String   @id @default(uuid())
  schoolId  String
  recipient String
  message   String
  language  String   @default("fr")
  status    String
  provider  String   @default("africas_talking")
  costFc    Int?
  sentAt    DateTime @default(now())
  errorMsg  String?
  school    School   @relation(fields: [schoolId], references: [id])

  @@map("sms_logs")
}

model Setting {
  id        String   @id @default(uuid())
  schoolId  String
  key       String
  value     String
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, key])
  @@map("settings")
}

model CashSession {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  date      DateTime
  cashierId String
  cashier   User     @relation("CashSessions", fields: [cashierId], references: [id])

  openingBalance Int // Solde ouverture
  closingBalance Int? // Solde fermeture (après comptage)

  totalReceived Int // Total encaissements
  totalSpent    Int // Total dépenses

  theoreticalBalance Int // Calculé : opening + received - spent
  actualBalance      Int? // Compté physiquement

  discrepancy Int? // Écart : actual - theoretical

  status String @default("OPEN") // OPEN, CLOSED, VALIDATED

  openedAt DateTime  @default(now())
  closedAt DateTime?

  movements CashMovement[]

  @@unique([schoolId, date, cashierId])
  @@map("cash_sessions")
}

model CashMovement {
  id        String      @id @default(uuid())
  sessionId String
  session   CashSession @relation(fields: [sessionId], references: [id])

  type     String // IN | OUT
  category String // PAYMENT | EXPENSE | OPENING | CLOSING

  amount  Int
  balance Int // Solde après mouvement

  reference   String? // N° reçu ou N° dépense
  description String?

  receiptUrl String? // Justificatif uploadé

  createdAt DateTime @default(now())

  @@index([sessionId, createdAt])
  @@map("cash_movements")
}

model Budget {
  id                  String   @id @default(uuid())
  schoolId            String
  academicYearId      String
  monthlyDistribution String   @default("UNIFORM") // UNIFORM | CUSTOM
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  school       School           @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear     @relation(fields: [academicYearId], references: [id])
  categories   BudgetCategory[]
  months       BudgetMonth[]

  @@unique([schoolId, academicYearId])
  @@map("budgets")
}

model BudgetCategory {
  id       String @id @default(uuid())
  budgetId String
  name     String
  amount   Int // Montant budgétisé
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@map("budget_categories")
}

model BudgetMonth {
  id       String @id @default(uuid())
  budgetId String
  month    Int // 1-12
  amount   Int // Montant prévu pour ce mois
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([budgetId, month])
  @@map("budget_months")
}

model Justification {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  attendanceRecordId String
  attendanceRecord   Attendance @relation(fields: [attendanceRecordId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  reason        String
  reasonDetails String

  documentUrl  String
  documentName String
  documentSize Int // Bytes

  status String @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED

  submittedById String
  submittedBy   User   @relation("JustificationSubmitter", fields: [submittedById], references: [id])

  reviewedById    String?
  reviewedBy      User?     @relation("JustificationReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  reviewComment   String?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([studentId])
  @@map("justifications")
}

model SMSCampaign {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  name          String?
  template      String
  recipientType String // PARENTS, TEACHERS, ALL

  totalRecipients   Int
  validRecipients   Int
  invalidRecipients Int

  status      String    @default("QUEUED") // QUEUED, SCHEDULED, SENDING, COMPLETED, FAILED, CANCELLED
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  sentSMS   Int   @default(0)
  failedSMS Int   @default(0)
  cost      Float @default(0)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  messages SMSMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, status])
  @@index([createdAt])
  @@map("sms_campaigns")
}

model SMSMessage {
  id         String      @id @default(uuid())
  campaignId String
  campaign   SMSCampaign @relation(fields: [campaignId], references: [id])

  phone   String
  message String

  status       String  @default("PENDING") // PENDING, SENT, FAILED
  errorMessage String?

  messageId String?
  cost      Float?

  sentAt DateTime?

  createdAt DateTime @default(now())

  @@index([campaignId, status])
  @@map("sms_messages")
}

// ── Email Campaigns ────────────────────────────────────────────────────────────

model EmailCampaign {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  subject         String
  htmlContent     String
  recipientType   String // PARENTS, TEACHERS, ALL
  recipientEmails String // JSON array of emails

  totalRecipients Int
  sentEmails      Int @default(0)
  failedEmails    Int @default(0)

  status      String    @default("QUEUED") // QUEUED, SCHEDULED, SENDING, COMPLETED, FAILED
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  attachmentUrls String @default("[]") // JSON array of stored file paths

  createdById String
  createdBy   User   @relation("EmailCampaignCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, status])
  @@index([createdAt])
  @@map("email_campaigns")
}

// ── Convocations ───────────────────────────────────────────────────────────────

model Convocation {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  numero String // CONV-2026-042 (unique par schoolId + année)

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  parentName    String // Nom complet du tuteur convoqué
  parentPhone   String? // Téléphone (pour SMS de rappel)
  parentEmail   String? // Email (si disponible via parentUserId)
  parentQualite String // Père, Mère, Tuteur, Les deux parents

  motif   String // RESULTATS_INSUFFISANTS, ABSENCES_REPETEES, etc.
  details String

  dateRendezVous  DateTime
  heureRendezVous String // HH:MM
  lieu            String   @default("Bureau du Préfet")

  status String @default("PENDING") // PENDING, CONFIRMED, ATTENDED, MISSED, CANCELLED

  confirmedAt DateTime?
  attendedAt  DateTime?

  pdfUrl String?

  emailSent Boolean @default(false)
  smsSent   Boolean @default(false)

  notes   String? // Compte-rendu entretien
  actions String  @default("[]") // JSON array d'actions décidées

  reminderD3Sent Boolean @default(false)
  reminderD1Sent Boolean @default(false)

  createdById String
  createdBy   User   @relation("ConvocationCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, numero])
  @@index([studentId, status])
  @@index([dateRendezVous])
  @@index([schoolId, createdAt])
  @@map("convocations")
}

// ── Announcements ──────────────────────────────────────────────────────────────

model Announcement {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  priority String // INFO, URGENT, CRITIQUE
  titre    String
  message  String

  audience String @default("[]") // JSON: ["PARENTS","TEACHERS","STAFF"]
  classIds String @default("[]") // JSON: [] = toutes les classes

  startDate DateTime
  endDate   DateTime

  isPinned Boolean @default(false)
  sendPush Boolean @default(false)

  views AnnouncementView[]

  createdById String
  createdBy   User   @relation("AnnouncementCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, startDate, endDate])
  @@map("announcements")
}

model AnnouncementView {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("AnnouncementViews", fields: [userId], references: [id])

  viewedAt DateTime @default(now())

  @@unique([announcementId, userId])
  @@map("announcement_views")
}

// ── Reports ────────────────────────────────────────────────────────────────────

model SavedReport {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  name    String
  type    String // PRESENCE, RESULTS, FINANCE, EFFECTIFS, END_OF_YEAR, CUSTOM
  filters String @default("{}") // JSON
  options String @default("{}") // JSON

  pdfUrl   String?
  excelUrl String?

  generatedById String
  generatedBy   User   @relation("SavedReportCreator", fields: [generatedById], references: [id])

  createdAt DateTime @default(now())

  @@index([schoolId, type])
  @@map("saved_reports")
}

model ExportHistory {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  type     String // STUDENTS, FINANCE, PRESENCE, RESULTS, TEACHERS, FULL
  filename String
  format   String // EXCEL, PDF, ZIP, CSV
  fileSize Int    @default(0)
  fileUrl  String

  filters String @default("{}") // JSON

  generatedById String
  generatedBy   User   @relation("ExportHistoryCreator", fields: [generatedById], references: [id])

  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
  @@map("export_history")
}

model ExportSchedule {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  type       String // STUDENTS, FINANCE, PRESENCE, RESULTS, TEACHERS, FULL
  frequency  String // MONTHLY, WEEKLY, QUARTERLY
  dayOfMonth Int?
  dayOfWeek  Int?
  time       String // "08:00"
  format     String
  recipients String @default("[]") // JSON array emails

  isActive  Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime

  createdById String
  createdBy   User   @relation("ExportScheduleCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, isActive])
  @@map("export_schedules")
}

// ── Inventory: Material ───────────────────────────────────────────────────────

model MaterialItem {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  name     String
  category String // MOBILIER, INFORMATIQUE, PEDAGOGIQUE, FOURNITURES, SPORT, AUTRE

  goodQty   Int @default(0)
  usedQty   Int @default(0)
  brokenQty Int @default(0)

  unitValue Float @default(0)
  minStock  Int   @default(0)

  location   String?
  acquiredAt DateTime?
  notes      String?

  movements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, category])
  @@map("material_items")
}

model StockMovement {
  id     String       @id @default(uuid())
  itemId String
  item   MaterialItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  type       String // ENTRY, EXIT, STATUS_CHANGE
  quantity   Int
  fromStatus String? // GOOD, USED, BROKEN
  toStatus   String? // GOOD, USED, BROKEN
  reason     String
  date       DateTime

  createdById String
  createdBy   User   @relation("StockMovementCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([itemId, createdAt])
  @@map("stock_movements")
}

// ── Inventory: Library ────────────────────────────────────────────────────────

model Book {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  titre   String
  auteur  String?
  isbn    String?
  matiere String
  niveaux String  @default("[]") // JSON array of integers [4, 5, 6]

  totalQty     Int
  availableQty Int
  etat         String // BON, PASSABLE, MAUVAIS

  unitValue  Float?
  acquiredAt DateTime?

  loans BookLoan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, matiere])
  @@map("books")
}

model BookLoan {
  id     String @id @default(uuid())
  bookId String
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  exemplaire String?
  notes      String?

  loanDate       DateTime
  expectedReturn DateTime
  actualReturn   DateTime?

  etatRetour     String? // BON, DEGRADE, ENDOMMAGE
  coutReparation Float?

  status String @default("ACTIVE") // ACTIVE, RETURNED, OVERDUE

  createdById String
  createdBy   User   @relation("BookLoanCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([bookId, status])
  @@index([studentId, status])
  @@map("book_loans")
}

// ── Inventory: Rooms ──────────────────────────────────────────────────────────

model Room {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  name     String
  type     String // CLASSROOM, LABORATORY, OFFICE, TEACHERS_ROOM, LIBRARY, SPORTS, CAFETERIA, OTHER
  capacity Int
  status   String @default("GOOD") // GOOD, DEGRADED, CLOSED

  building String?
  floor    String?

  assignedClassId String?  @unique
  assignedClass   Class?   @relation("RoomAssignedClass", fields: [assignedClassId], references: [id])
  responsableId   String?
  responsable     Teacher? @relation("RoomResponsable", fields: [responsableId], references: [id])

  equipments       String  @default("[]") // JSON array of strings
  stateDescription String?

  maintenanceRequests MaintenanceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId, type, status])
  @@index([responsableId])
  @@map("rooms")
}

// ── Inventory: Maintenance ────────────────────────────────────────────────────

model MaintenanceRequest {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  titre    String
  category String // PLOMBERIE, ELECTRICITE, MENUISERIE, PEINTURE, INFORMATIQUE, AUTRE
  urgency  String // URGENT, NORMAL, LOW

  roomId   String?
  room     Room?   @relation(fields: [roomId], references: [id])
  location String?

  description String
  photoUrl    String?

  status String @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED, CANCELLED

  technicien    String?
  estimatedCost Float?
  actualCost    Float?

  startDate DateTime?
  endDate   DateTime?
  progress  Int       @default(0) // 0-100

  notes String?

  reportedById String
  reportedBy   User   @relation("MaintenanceReporter", fields: [reportedById], references: [id])

  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, status, urgency])
  @@index([roomId])
  @@map("maintenance_requests")
}

// ── SaaS: Plans d'Abonnement ─────────────────────────────────────────────────

model SubscriptionPlan {
  id             String   @id @default(uuid())
  name           String   // "Essai", "Bronze", "Argent", "Or"
  slug           String   @unique // "trial", "bronze", "silver", "gold"
  priceUSD       Float    @default(0)
  priceCDF       Float    @default(0)
  maxStudents    Int      @default(300)  // -1 = illimité
  maxTeachers    Int      @default(20)
  maxSmsPerMonth Int      @default(100)
  durationDays   Int      @default(30)
  features       String   @default("[]") // JSON string des fonctionnalités incluses
  isActive       Boolean  @default(true)

  schools School[]

  @@map("subscription_plans")
}

// ── SaaS: Abonnements des Écoles ─────────────────────────────────────────────

model Subscription {
  id            String   @id @default(uuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])

  planId        String?

  startDate     DateTime
  endDate       DateTime
  status        String   // "TRIAL" | "ACTIVE" | "EXPIRED" | "SUSPENDED" | "PENDING"

  amountPaid    Float    @default(0)
  currency      String   @default("USD")
  paymentRef    String?  // Référence du paiement Mobile Money / Carte
  paymentMethod String?  // "MPESA" | "AIRTEL_MONEY" | "ORANGE_MONEY" | "FLEXPAY" | "MANUAL"

  notes         String?

  createdAt     DateTime @default(now())

  @@index([schoolId, status])
  @@index([endDate])
  @@map("subscriptions")
}

model Notification {
  id        String    @id @default(uuid())
  schoolId  String?
  userId    String?
  type      String    // SUB_EXPIRING_30 | SUB_EXPIRING_7 | SUB_EXPIRING_1 | SMS_QUOTA_80 | SMS_QUOTA_100 | PAYMENT_SUCCESS | PAYMENT_FAILED | NEW_SCHOOL | ANOMALY
  title     String
  message   String
  channel   String    // IN_APP | EMAIL | SMS
  isRead    Boolean   @default(false)
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, isRead])
  @@index([schoolId])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  actorRole String?
  actorName String?
  schoolId  String?
  schoolName String?
  action    String   // LOGIN | LOGOUT | CREATE | UPDATE | DELETE | EXPORT | SUSPEND | ACTIVATE | PAYMENT | etc.
  entity    String?  // School | Student | Teacher | Subscription | Plan | User
  entityId  String?
  summary   String?  // Human-readable description
  before    String?  // JSON snapshot before change
  after     String?  // JSON snapshot after change
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
