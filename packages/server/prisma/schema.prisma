generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model School {
  id                 String              @id @default(uuid())
  name               String
  logoUrl            String?
  type               String
  convention         String?
  agrement           String?
  province           String              @default("Nord-Kivu")
  ville              String              @default("Goma")
  commune            String?
  adresse            String?
  telephone          String?
  email              String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  code               String?
  academicYears      AcademicYear[]
  classes            Class[]
  feeTypes           FeeType[]
  payments           Payment[]
  sections           Section[]
  settings           Setting[]
  smsLogs            SmsLog[]
  students           Student[]
  subjects           Subject[]
  teacherAttendances TeacherAttendance[]
  teacherLeaves      TeacherLeave[]
  teachers           Teacher[]
  users              User[]

  @@map("schools")
}

model User {
  id                     String              @id @default(uuid())
  schoolId               String
  nom                    String
  postNom                String
  prenom                 String?
  email                  String?
  phone                  String
  passwordHash           String
  role                   String
  isActive               Boolean             @default(true)
  lastLoginAt            DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  attendanceTaken        Attendance[]
  gradesCreated          Grade[]
  paymentsCreated        Payment[]
  teacherAttendanceTaken TeacherAttendance[]
  leaveProcessing        TeacherLeave[]      @relation("LeaveProcessor")
  teacher                Teacher?
  school                 School              @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, phone])
  @@unique([schoolId, email])
  @@map("users")
}

model OtpToken {
  id        String   @id @default(uuid())
  phone     String
  otpHash   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_tokens")
}

model AcademicYear {
  id          String       @id @default(uuid())
  schoolId    String
  label       String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  school      School       @relation(fields: [schoolId], references: [id])
  enrollments Enrollment[]
  feeTypes    FeeType[]
  payments    Payment[]
  terms       Term[]

  @@unique([schoolId, label])
  @@map("academic_years")
}

model Term {
  id             String         @id @default(uuid())
  academicYearId String
  number         Int
  label          String
  startDate      DateTime
  endDate        DateTime
  examStartDate  DateTime?
  examEndDate    DateTime?
  isActive       Boolean        @default(false)
  attendances    Attendance[]
  deliberations  Deliberation[]
  grades         Grade[]
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])

  @@unique([academicYearId, number])
  @@map("terms")
}

model Section {
  id       String           @id @default(uuid())
  schoolId String
  name     String
  code     String
  year     Int
  classes  Class[]
  school   School           @relation(fields: [schoolId], references: [id])
  subjects SubjectSection[]

  @@unique([schoolId, code, year])
  @@map("sections")
}

model Class {
  id                 String                @id @default(uuid())
  schoolId           String
  sectionId          String
  name               String
  maxStudents        Int                   @default(45)
  isActive           Boolean               @default(true)
  attendances        Attendance[]
  section            Section               @relation(fields: [sectionId], references: [id])
  school             School                @relation(fields: [schoolId], references: [id])
  deliberations      Deliberation[]
  enrollments        Enrollment[]
  teacherAssignments TeacherClassSubject[]

  @@unique([schoolId, name])
  @@map("classes")
}

model Subject {
  id            String                @id @default(uuid())
  schoolId      String
  name          String
  abbreviation  String
  maxScore      Int                   @default(20)
  isEliminatory Boolean               @default(false)
  elimThreshold Float?
  displayOrder  Int                   @default(0)
  grades        Grade[]
  sections      SubjectSection[]
  school        School                @relation(fields: [schoolId], references: [id])
  assignments   TeacherClassSubject[]
  teachers      Teacher[]             @relation("TeacherSubjects")

  @@unique([schoolId, abbreviation])
  @@map("subjects")
}

model SubjectSection {
  subjectId   String
  sectionId   String
  coefficient Int     @default(1)
  section     Section @relation(fields: [sectionId], references: [id])
  subject     Subject @relation(fields: [subjectId], references: [id])

  @@id([subjectId, sectionId])
  @@map("subject_sections")
}

model Student {
  id                String             @id @default(uuid())
  schoolId          String
  matricule         String
  nom               String
  postNom           String
  prenom            String?
  sexe              String
  dateNaissance     DateTime
  lieuNaissance     String
  nationalite       String             @default("Congolaise")
  photoUrl          String?
  nomPere           String?
  telPere           String?
  nomMere           String?
  telMere           String?
  nomTuteur         String?
  telTuteur         String?
  statut            String             @default("NOUVEAU")
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  attendances       Attendance[]
  disciplineRecords DisciplineRecord[]
  enrollments       Enrollment[]
  grades            Grade[]
  payments          Payment[]
  school            School             @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, matricule])
  @@map("students")
}

model Enrollment {
  id               String       @id @default(uuid())
  studentId        String
  classId          String
  academicYearId   String
  ecoleOrigine     String?
  resultatTenasosp Float?
  enrolledAt       DateTime     @default(now())
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id])
  class            Class        @relation(fields: [classId], references: [id])
  student          Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, academicYearId])
  @@map("enrollments")
}

model Teacher {
  id               String                @id @default(uuid())
  schoolId         String
  matricule        String                @unique
  matriculeMepst   String?
  nom              String
  postNom          String
  prenom           String?
  sexe             String
  dateNaissance    DateTime?
  lieuNaissance    String?
  nationalite      String                @default("Congolaise")
  telephone        String?
  email            String?
  adresse          String?
  photoUrl         String?
  niveauEtudes     String?
  domaineFormation String?
  universite       String?
  anneeObtention   Int?
  specialisations  String?
  compteBancaire   String?
  statut           String                @default("ACTIF")
  dateEmbauche     DateTime?
  typeContrat      String?
  fonction         String?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  userId           String?               @unique
  congeGlobal      Int                   @default(20)
  congePris        Int                   @default(0)
  attendances      TeacherAttendance[]
  certificats      TeacherCertificate[]
  assignments      TeacherClassSubject[]
  leaves           TeacherLeave[]
  user             User?                 @relation(fields: [userId], references: [id])
  school           School                @relation(fields: [schoolId], references: [id])
  subjects         Subject[]             @relation("TeacherSubjects")

  @@unique([schoolId, telephone])
  @@map("teachers")
}

model TeacherLeave {
  id            String   @id @default(uuid())
  teacherId     String
  schoolId      String
  type          String
  startDate     DateTime
  endDate       DateTime
  daysCount     Int
  status        String   @default("PENDING")
  reason        String
  observations  String?
  certificatUrl String?
  processedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  processedBy   User?    @relation("LeaveProcessor", fields: [processedById], references: [id])
  school        School   @relation(fields: [schoolId], references: [id])
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_leaves")
}

model TeacherCertificate {
  id         String  @id @default(uuid())
  teacherId  String
  nom        String
  organisme  String
  annee      Int
  fichierUrl String?
  teacher    Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_certificates")
}

model TeacherClassSubject {
  id               String            @id @default(uuid())
  teacherId        String
  classId          String
  subjectId        String
  academicYearId   String
  volumeHoraire    Int?              @default(0)
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class            Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher          Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  timetablePeriods TimetablePeriod[]

  @@unique([teacherId, classId, subjectId, academicYearId])
  @@map("teacher_class_subjects")
}

model TimetablePeriod {
  id                    String              @id @default(uuid())
  teacherClassSubjectId String
  dayOfWeek             String
  periodSlot            Int
  startTime             String
  endTime               String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  teacherClassSubject   TeacherClassSubject @relation(fields: [teacherClassSubjectId], references: [id], onDelete: Cascade)

  @@unique([teacherClassSubjectId, dayOfWeek, periodSlot])
  @@index([dayOfWeek, periodSlot])
  @@map("timetable_periods")
}

model Grade {
  id          String   @id @default(uuid())
  studentId   String
  subjectId   String
  termId      String
  evalType    String
  score       Float
  maxScore    Int      @default(20)
  observation String?
  isLocked    Boolean  @default(false)
  syncStatus  String   @default("SYNCED")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id])
  term        Term     @relation(fields: [termId], references: [id])
  subject     Subject  @relation(fields: [subjectId], references: [id])
  student     Student  @relation(fields: [studentId], references: [id], onDelete: NoAction)

  @@unique([studentId, subjectId, termId, evalType])
  @@map("grades")
}

model Deliberation {
  id          String        @id @default(uuid())
  classId     String
  termId      String
  status      String        @default("DRAFT")
  validatedAt DateTime?
  pvUrl       String?
  createdAt   DateTime      @default(now())
  results     DelibResult[]
  term        Term          @relation(fields: [termId], references: [id])
  class       Class         @relation(fields: [classId], references: [id])

  @@unique([classId, termId])
  @@map("deliberations")
}

model DelibResult {
  id             String       @id @default(uuid())
  deliberationId String
  studentId      String
  generalAverage Float
  totalPoints    Float
  rank           Int
  decision       String
  justification  String?
  deliberation   Deliberation @relation(fields: [deliberationId], references: [id])

  @@unique([deliberationId, studentId])
  @@map("delib_results")
}

model Attendance {
  id            String   @id @default(uuid())
  studentId     String
  classId       String
  termId        String
  date          DateTime
  period        String
  status        String
  justification String?
  syncStatus    String   @default("SYNCED")
  recordedById  String
  createdAt     DateTime @default(now())
  recordedBy    User     @relation(fields: [recordedById], references: [id])
  term          Term     @relation(fields: [termId], references: [id])
  class         Class    @relation(fields: [classId], references: [id])
  student       Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, date, period])
  @@map("attendances")
}

model TeacherAttendance {
  id            String   @id @default(uuid())
  teacherId     String
  schoolId      String
  date          DateTime
  status        String
  justification String?
  recordedById  String
  createdAt     DateTime @default(now())
  recordedBy    User     @relation(fields: [recordedById], references: [id])
  school        School   @relation(fields: [schoolId], references: [id])
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, date])
  @@map("teacher_attendances")
}

model DisciplineRecord {
  id          String   @id @default(uuid())
  studentId   String
  date        DateTime
  description String
  witnesses   String?
  sanction    String
  status      String   @default("OPEN")
  resolution  String?
  createdAt   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id])

  @@map("discipline_records")
}

model FeeType {
  id             String        @id @default(uuid())
  schoolId       String
  academicYearId String?
  type           String        @default("AUTRE")
  name           String
  amount         Int
  scope          String        @default("SCHOOL")
  sectionIds     String        @default("[]")
  classIds       String        @default("[]")
  frequency      String        @default("ANNUAL")
  months         String        @default("[]")
  termNumber     Int?
  isRequired     Boolean       @default(true)
  observations   String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  deletedAt      DateTime?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id])
  feePayments    FeePayment[]

  @@index([schoolId, academicYearId, isActive])
  @@map("fee_types")
}

model Payment {
  id               String       @id @default(uuid())
  schoolId         String
  academicYearId   String
  receiptNumber    String       @unique
  studentId        String

  // Montants
  totalDue         Int
  amountPaid       Int
  remainingBalance Int          @default(0)
  currency         String       @default("FC")
  exchangeRate     Float?

  // Méthode de paiement
  paymentMethod    String
  transactionRef   String?
  paymentDate      DateTime     @default(now())

  // Métadonnées
  cashierId        String
  observations     String?
  receiptUrl       String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @default(now()) @updatedAt

  // Relations
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id])
  school           School       @relation(fields: [schoolId], references: [id])
  student          Student      @relation(fields: [studentId], references: [id])
  cashier          User         @relation(fields: [cashierId], references: [id])
  feePayments      FeePayment[]

  @@index([schoolId, studentId])
  @@index([receiptNumber])
  @@index([paymentDate])
  @@map("payments")
}

model FeePayment {
  id          String   @id @default(uuid())
  paymentId   String
  feeId       String
  amountDue   Int
  amountPaid  Int
  createdAt   DateTime @default(now())

  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  fee         FeeType  @relation(fields: [feeId], references: [id])

  @@unique([paymentId, feeId])
  @@map("fee_payments")
}

model SmsLog {
  id        String   @id @default(uuid())
  schoolId  String
  recipient String
  message   String
  language  String   @default("fr")
  status    String
  provider  String   @default("africas_talking")
  costFc    Int?
  sentAt    DateTime @default(now())
  errorMsg  String?
  school    School   @relation(fields: [schoolId], references: [id])

  @@map("sms_logs")
}

model Setting {
  id        String   @id @default(uuid())
  schoolId  String
  key       String
  value     String
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, key])
  @@map("settings")
}
